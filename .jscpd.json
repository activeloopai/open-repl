{
  "threshold": 7,
  "reporters": ["console", "markdown"],
  "output": "./jscpd-report",
  "ignore": [
    "**/node_modules/**",
    "**/dist/**",
    "**/coverage/**",
    "**/.test-tmp/**",
    "**/*.test.ts",
    "**/test/**",
    "**/scripts/**"
  ],
  "absolute": false,
  "gitignore": true,
  "format": ["typescript", "tsx"],
  "minLines": 10,
  "minTokens": 60
}
